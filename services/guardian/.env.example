# Throtl guardian — copy to .env for local dev. Railway injects these as service variables.
NODE_ENV=development
PORT=8080

# Solana / MagicBlock / Flash (public defaults verified in docs/VERSIONS.md).
BASE_RPC_URL=https://api.devnet.solana.com
FLASH_ER_RPC_URL=https://flash.magicblock.xyz
FLASH_API_URL=https://flashapi.trade/v2
PYTH_HERMES_URL=https://hermes.pyth.network

# Secret upstream RPC proxied for the client (web). Leave blank in dev.
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# FCM push relay service account (firebase-admin). JSON string; wired in M5.
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Comma-separated allowed origins for proxy/incident endpoints (web domains).
ALLOWED_ORIGINS=*
