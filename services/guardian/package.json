{
  "name": "@throtl/guardian",
  "version": "0.1.0",
  "private": true,
  "description": "Throtl server-side guardian (Railway): off-phone loss-floor watcher, FCM push relay, RPC-key proxy, incident sink, contract-drift canary. Holds NO user keys — its only money-moving capability is a user-pre-signed, close-only (flatten) transaction (FEASIBILITY DR-8).",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node24 --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "1.98.2",
    "@solana/spl-token": "0.4.14",
    "hono": "4.12.25",
    "@hono/node-server": "2.0.4",
    "ws": "8.21.0",
    "zod": "4.4.3",
    "pino": "10.3.1",
    "firebase-admin": "14.0.0"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "tsx": "4.22.4",
    "tsup": "8.5.1",
    "vitest": "4.1.8",
    "pino-pretty": "13.1.3",
    "@types/node": "24.13.2",
    "@types/ws": "8.18.1"
  }
}
